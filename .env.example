# Backend
PORT=8080
APP_ENV=dev

# Путь к данным модулей / курсов (для файлового store)
DATA_PATH=data/modules

# PostgreSQL (при запуске через Docker: docker compose up -d)
# Локально с docker-compose: postgres://hackpet:hackpet@localhost:5432/hackpet?sslmode=disable
DB_DSN=postgres://hackpet:hackpet@localhost:5432/hackpet?sslmode=disable

# JWT секрет для токенов авторизации (заполнить в .env, а не коммитить)
JWT_SECRET=

